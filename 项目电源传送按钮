local btn = Instance.new("ImageButton")
btn.Size = UDim2.new(0.05, 0, 0.12, 0)
btn.Position = UDim2.new(0.645, 0, 0.815, 0)
btn.BackgroundTransparency = 1
btn.Image = "rbxassetid://100601425820983"
btn.ImageColor3 = Color3.fromRGB(100, 255, 100)
btn.Parent = gui

local isHolding = false
local animTrack = nil
local holdConnection = nil

local function getCharacter()
	return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function playAnimation()
	local character = getCharacter()
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://89051176234077"
	animTrack = humanoid:LoadAnimation(anim)
	animTrack:Play()
end

local function stopAnimation()
	if animTrack then
		animTrack:Stop()
		animTrack = nil
	end
end

local function sendBlockRemove()
	local character = getCharacter()
	local args = {
		"Angstrom",
		"Block",
		[4] = "BlockAdd",
		character,
	}
	abilityRemote:FireServer(unpack(args))
end

local function sendBlockAdd()
	local character = getCharacter()
	local args = {
		"Angstrom",
		"Block",
		[4] = "BlockRemove",
		character,
	}
	abilityRemote:FireServer(unpack(args))
end

btn.MouseButton1Down:Connect(function()
	isHolding = true
	sendBlockRemove()
	playAnimation()
	
	holdConnection = RunService.Heartbeat:Connect(function()
		if not isHolding then
			holdConnection:Disconnect()
			holdConnection = nil
		end
	end)
end)

btn.MouseButton1Up:Connect(function()
	if isHolding then
		isHolding = false
		stopAnimation()
		sendBlockAdd()
		
		if holdConnection then
			holdConnection:Disconnect()
			holdConnection = nil
		end
	end
end)

btn.MouseLeave:Connect(function()
	if isHolding then
		isHolding = false
		stopAnimation()
		sendBlockAdd()
		
		if holdConnection then
			holdConnection:Disconnect()
			holdConnection = nil
		end
	end
end)

