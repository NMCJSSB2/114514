local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

local AIFolder = Workspace:WaitForChild("AI")

local AimbotEnabled = false
local npcRecords = {}

local MaxDistance = 1000
local FOV = 250

local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.ResetOnSpawn = false

local ToggleButton = Instance.new("ImageButton")
ToggleButton.Size = UDim2.new(0, 100, 0, 40)
ToggleButton.Position = UDim2.new(0, 10, 0, 10)
ToggleButton.BackgroundTransparency = 1
ToggleButton.Image = "rbxassetid://136268399740002"
ToggleButton.ImageColor3 = Color3.fromRGB(255,255,255)
ToggleButton.Parent = ScreenGui

local originalPos = ToggleButton.Position
local pressed = false

local function updateColor()
	local targetColor
	if AimbotEnabled then
		targetColor = Color3.fromRGB(0,170,255)
	else
		targetColor = Color3.fromRGB(255,255,255)
	end
	TweenService:Create(
		ToggleButton,
		TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ImageColor3 = targetColor}
	):Play()
end

ToggleButton.MouseButton1Down:Connect(function()
	if pressed then return end
	pressed = true
	TweenService:Create(ToggleButton, TweenInfo.new(0.08), {
		Position = originalPos + UDim2.new(0,10,0,0)
	}):Play()
end)

ToggleButton.MouseButton1Up:Connect(function()
	if not pressed then return end
	pressed = false
	AimbotEnabled = not AimbotEnabled
	TweenService:Create(ToggleButton, TweenInfo.new(0.08), {
		Position = originalPos
	}):Play()
	updateColor()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.Q then
		AimbotEnabled = not AimbotEnabled
		updateColor()
	end
end)

local function isVisible(targetPart)
	local origin = Camera.CFrame.Position
	local direction = (targetPart.Position - origin)
	local distance = direction.Magnitude
	direction = direction.Unit
	
	local mech = Workspace:FindFirstChild("Mech_" .. LocalPlayer.Name)
	
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	
	local ignoreList = {LocalPlayer.Character}
	if mech then
		table.insert(ignoreList, mech)
	end
	
	params.FilterDescendantsInstances = ignoreList
	
	local currentOrigin = origin
	local remainingDistance = distance
	
	for i = 1, 5 do
		local ray = Workspace:Raycast(currentOrigin, direction * remainingDistance, params)
		
		if not ray then
			return true
		end
		
		local hit = ray.Instance
		
		if hit:IsDescendantOf(targetPart.Parent) then
			return true
		end
		
		if hit.Transparency >= 0.9 then
			table.insert(ignoreList, hit)
			params.FilterDescendantsInstances = ignoreList
			
			local hitPos = ray.Position
			local traveled = (hitPos - currentOrigin).Magnitude
			
			remainingDistance -= traveled
			currentOrigin = hitPos + direction * 0.1
			
			continue
		end
		
		return false
	end
	
	return false
end

local function screenDistance(targetPos)
	local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
	if onScreen then
		local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
		return (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
	end
	return math.huge
end

local function getTarget()
	local closestPart
	local closestDist = math.huge
	
	for _, npc in pairs(AIFolder:GetChildren()) do
		if npc:IsA("Model") then
			local humanoid = npc:FindFirstChildOfClass("Humanoid")
			if humanoid and humanoid.Health > 0 then
				
				local targetPart
				
				if npc.Name == "Tarantula" or npc.Name == "Chimera1" or npc.Name == "Chimera2" then
					local weakFolder = npc:FindFirstChild("Weakpoints")
					if weakFolder then
						targetPart = weakFolder:FindFirstChild("Weakpoint")
					end
					
				elseif npc.Name == "Dracula" then
					targetPart = npc:FindFirstChild("HumanoidRootPart")
					
				else
					targetPart = npc:FindFirstChild("Head")
				end
				
				if targetPart then
					local distance = (targetPart.Position - Camera.CFrame.Position).Magnitude
					
					if distance < MaxDistance and isVisible(targetPart) then
						local dist = screenDistance(targetPart.Position)
						
						if dist <= FOV and dist < closestDist then
							closestDist = dist
							closestPart = targetPart
						end
					end
				end
			end
		end
	end
	
	return closestPart
end

local function addEnemyBillboard(npc)
	if npcRecords[npc] then return end
	
	local targetPart
	
	if npc.Name == "Tarantula" or npc.Name == "Chimera1" or npc.Name == "Chimera2" then
		local weakFolder = npc:FindFirstChild("Weakpoints")
		if weakFolder then
			targetPart = weakFolder:FindFirstChild("Weakpoint")
			if targetPart then
				targetPart.Size = Vector3.new(3,3,3)
			end
		end
		
	elseif npc.Name == "Dracula" then
		targetPart = npc:FindFirstChild("HumanoidRootPart")
		
	else
		targetPart = npc:FindFirstChild("Head")
	end
	
	if not targetPart then return end
	
	local billboard = Instance.new("BillboardGui")
	billboard.Adornee = targetPart
	billboard.Size = UDim2.new(0,100,0,40)
	billboard.AlwaysOnTop = true
	billboard.StudsOffset = Vector3.new(0,2.5,0)
	
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.TextStrokeTransparency = 0
	label.Font = Enum.Font.SourceSansBold
	label.TextSize = 23
	label.Parent = billboard
	
	billboard.Parent = npc
	
	npcRecords[npc] = {
		gui = billboard,
		label = label,
		part = targetPart
	}
end

local function updateBillboards()
	for npc, data in pairs(npcRecords) do
		if not npc.Parent then
			data.gui:Destroy()
			npcRecords[npc] = nil
		else
			local humanoid = npc:FindFirstChildOfClass("Humanoid")
			local dead = humanoid and humanoid.Health <= 0
			local visible = data.part and isVisible(data.part)
			
			if npc.Name == "Tarantula" then
				data.label.Text = "机械蛛"
				data.label.TextColor3 = Color3.fromRGB(0,150,255)
			elseif npc.Name == "Chimera1" then
				data.label.Text = "机枪兵"
				data.label.TextColor3 = Color3.fromRGB(255,140,0)
			elseif npc.Name == "Chimera2" then
				data.label.Text = "机枪兵2"
				data.label.TextColor3 = Color3.fromRGB(255,140,0)
			elseif npc.Name == "Dracula" then
				data.label.Text = "战争机器"
				data.label.TextColor3 = Color3.fromRGB(139,0,0)
			else
				data.label.Text = "敌人"
				data.label.TextColor3 = Color3.fromRGB(255,0,0)
			end
			
			if dead then
				data.label.TextColor3 = Color3.fromRGB(0,0,0)
			elseif not visible then
				data.label.TextColor3 = Color3.fromRGB(120,120,120)
			end
		end
	end
	
	for _, npc in pairs(AIFolder:GetChildren()) do
		if npc:IsA("Model") then
			addEnemyBillboard(npc)
		end
	end
end

RunService.RenderStepped:Connect(function()
	updateBillboards()
	
	if AimbotEnabled then
		local target = getTarget()
		if target then
			local camPos = Camera.CFrame.Position
			local newCF = CFrame.lookAt(camPos, target.Position)
			Camera.CFrame = Camera.CFrame:Lerp(newCF, 0.6)
		end
	end
end)
