local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local function createGUI()
    if playerGui:FindFirstChild("AutoAttackGUI") then
        return
    end
    
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AutoAttackGUI"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui

    local button1 = Instance.new("ImageButton")
    button1.Name = "BasicAttack"
    button1.Size = UDim2.new(0, 60, 0, 60)
    button1.Position = UDim2.new(0.67, 0, 0.8, -45)
    button1.BackgroundTransparency = 1
    button1.Image = "rbxassetid://91223269317292"
    button1.Parent = screenGui

    local icon1 = Instance.new("ImageLabel")
    icon1.Name = "Icon"
    icon1.Size = UDim2.new(0, 40, 0, 40)
    icon1.Position = UDim2.new(0.5, -20, 0.5, -20)
    icon1.BackgroundTransparency = 1
    icon1.Image = "rbxassetid://132578184386101"
    icon1.ImageTransparency = 0
    icon1.Parent = button1

    local button2 = Instance.new("ImageButton")
    button2.Name = "AutoAttack"
    button2.Size = UDim2.new(0, 60, 0, 60)
    button2.Position = UDim2.new(0, 30, 0.5, -60)
    button2.BackgroundTransparency = 1
    button2.Image = "rbxassetid://91223269317292"
    button2.ImageColor3 = Color3.fromRGB(255, 0, 0)
    button2.Parent = screenGui

    local icon2 = Instance.new("ImageLabel")
    icon2.Name = "Icon"
    icon2.Size = UDim2.new(0, 40, 0, 40)
    icon2.Position = UDim2.new(0.5, -20, 0.5, -20)
    icon2.BackgroundTransparency = 1
    icon2.Image = "rbxassetid://132578184386101"
    icon2.ImageTransparency = 0
    icon2.Parent = button2

    local debounce = false

    button1.MouseButton1Down:Connect(function()
        if debounce then return end
        debounce = true

        local fadeIn = TweenService:Create(
            button1,
            TweenInfo.new(0.08, Enum.EasingStyle.Linear),
            {
                ImageTransparency = 0
            }
        )

        local fadeOut = TweenService:Create(
            button1,
            TweenInfo.new(0.15, Enum.EasingStyle.Linear),
            {
                ImageTransparency = 0.5
            }
        )

        fadeIn:Play()
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Attacks"):WaitForChild("BasicAttack"):FireServer()

        fadeIn.Completed:Connect(function()
            fadeOut:Play()
            fadeOut.Completed:Connect(function()
                debounce = false
            end)
        end)
    end)

    button1.ImageTransparency = 0.5

    local isActive = false
    local attackConnection = nil

    button2.MouseButton1Click:Connect(function()
        isActive = not isActive
        
        if isActive then
            button2.ImageTransparency = 0
            attackConnection = RunService.Heartbeat:Connect(function()
                ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Attacks"):WaitForChild("BasicAttack"):FireServer()
            end)
        else
            button2.ImageTransparency = 0.5
            if attackConnection then
                attackConnection:Disconnect()
                attackConnection = nil
            end
        end
    end)

    button2.ImageTransparency = 0.5
end

local function checkTeam()
    local team = player.Team
    if team and team.Name == "Killer" then
        createGUI()
    else
        local existingGUI = playerGui:FindFirstChild("AutoAttackGUI")
        if existingGUI then
            existingGUI:Destroy()
        end
    end
end

checkTeam()

player:GetPropertyChangedSignal("Team"):Connect(checkTeam)

player.CharacterAdded:Connect(function(character)
    checkTeam()
end)

task.spawn(function()
    while true do
        task.wait(2)
        checkTeam()
    end
end)
